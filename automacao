import pyautogui
import time
import webbrowser

py.autogui.PAUSE = 1
pyautogui.press('win')
time.sleep(0.5)
pyautogui.write('chrome')
time.sleep(0.5)
pyautogui.press('enter')
time.sleep(3)
pyautogui.write('https://open.spotify.com/intl-pt/track/79zgdvnTPyWSuTrd48Ik5O?si=791b75ed922b4dc6')
print('Abrindo Spotify...')
time.sleep(1)
pyautogui.press('enter')
time.sleep(5)

button_location = none
while button_location is none:
    button_location = pyautogui.locateOnScreen('play.png',confidence=0.7)
    print("procurando botão de play...")
    time.sleep(3)

button_point = pyautogui.center(button_location)
print("Botão play localizado")
pyautogui.click(button_point)
time.sleep(1)

pyautogui.hotkey("crl","t")
pyautogui.write("https://www.youtube.com/watch?v=sYC5BfJy2nw&list=RDsYC5BfJy2nw&start_radio=1")
pyautogui.press("enter")
print("Abrindo o Youtube..")
time.sleep(2)

pyautogui.press("M")
pyautogui.press("f")
print("Automação concluída!")